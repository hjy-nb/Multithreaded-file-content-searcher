


# 默认自动处理行尾符
* text=auto

# Java 源代码统一使用 LF
*.java text eol=lf

# 配置文件统一使用 LF
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 脚本文件统一使用 LF
*.sh text eol=lf
*.bash text eol=lf

# 文档文件统一使用 LF
*.md text eol=lf
*.txt text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不进行行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.class binary
